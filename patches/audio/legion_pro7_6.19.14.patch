-	unsigned int reg_val;
-	int ret, i;
-
-	ret = regmap_read(aw_dev->regmap, AW88399_PLLCTRL2_REG, &reg_val);
-	if (ret)
-		return ret;
-
-	reg_val &= (~AW88399_CCO_MUX_MASK);
-	if (reg_val == AW88399_CCO_MUX_DIVIDED_VALUE) {
-		dev_dbg(aw_dev->dev, "CCO_MUX is already divider");

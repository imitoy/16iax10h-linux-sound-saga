-		return ret;
-	/* enable fw crc check */
-	ret = regmap_update_bits(aw_dev->regmap, AW88399_CRCCTRL_REG,
-		~AW88399_CRC_CODE_EN_MASK, AW88399_CRC_CODE_EN_ENABLE_VALUE);
-
-	usleep_range(AW88399_2000_US, AW88399_2000_US + 10);

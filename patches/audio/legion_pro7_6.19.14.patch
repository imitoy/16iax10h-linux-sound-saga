-	aw88399_dev_set_dither(aw88399, false);
-
-	/* power on */
-	aw_dev_pwd(aw_dev, false);
-	usleep_range(AW88399_2000_US, AW88399_2000_US + 10);
-
-	ret = aw_dev_check_syspll(aw_dev);

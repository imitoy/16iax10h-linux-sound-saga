-	if (ret)
-		return ret;
-	if ((reg_val & AW88399_BIT_PLL_CHECK) != AW88399_BIT_PLL_CHECK) {
-		dev_err(aw_dev->dev, "check pll lock fail, reg_val:0x%04x", reg_val);
-		return -EINVAL;
-	}
-
-	return 0;

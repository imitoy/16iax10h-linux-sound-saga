-
-	/* change mode2 */
-	ret = regmap_update_bits(aw_dev->regmap, AW88399_PLLCTRL2_REG,
-			~AW88399_CCO_MUX_MASK, AW88399_CCO_MUX_DIVIDED_VALUE);
-	if (ret)

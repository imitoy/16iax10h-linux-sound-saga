 	SND_PCI_QUIRK(0x17aa, 0x38bf, "Yoga S980-14.5 proX LX Dual", ALC287_FIXUP_TAS2781_I2C),
@@ -7837,6 +7882,8 @@ static const struct hda_quirk alc269_fixup_tbl[] = {
